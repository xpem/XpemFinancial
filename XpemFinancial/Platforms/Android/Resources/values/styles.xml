<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MainTheme" parent="MainTheme.Base" />

    <style name="MainTheme.Base" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Cor da Toolbar (ActionBar) -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <!-- Cor da status bar -->
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <!-- Cor de destaque (cursor, focus, switches) -->
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Cor dos ícones da Toolbar: back button e hamburger menu -->
        <item name="colorOnPrimary">#d6e0eb</item>

        <!-- Cor do título da Toolbar -->
        <item name="android:textColorPrimary">#d6e0eb</item>

        <!-- Fundo da janela -->
        <item name="android:windowBackground">@color/colorBackground</item>

        <!-- Remove a sombra da ActionBar -->
        <item name="android:elevation">0dp</item>

        <!-- DatePicker / TimePicker dialog: botões OK/Cancel visíveis -->
        <item name="android:datePickerDialogTheme">@style/XpemDatePickerDialog</item>
        <item name="android:timePickerDialogTheme">@style/XpemDatePickerDialog</item>
    </style>

    <!-- Tema da splash screen — sobrescreve o fundo gerado pelo MAUI -->
    <style name="Maui.SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/colorPrimary</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/colorPrimary</item>
    </style>

    <!-- DatePicker dialog: botões OK/Cancel visíveis sobre fundo escuro -->
    <style name="XpemDatePickerDialog" parent="ThemeOverlay.MaterialComponents.Dialog">
        <item name="colorPrimary">@color/colorAccent</item>
        <item name="colorOnSurface">@color/colorFontLight</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="buttonStyle">@style/XpemDialogButton</item>
        <item name="android:buttonStyle">@style/XpemDialogButton</item>
    </style>

    <!-- Texto branco nos botões OK/Cancel do dialog -->
    <style name="XpemDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#ffffff</item>
    </style>
</resources>
