<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XpemFinancial.Components.NumericEntry"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XpemFinancial.Components"
    x:Name="this"
    x:DataType="local:NumericEntry">
    <VerticalStackLayout>
        <Entry
            x:Name="EntryNumeric"
            Keyboard="Numeric"
            MaxLength="999"
            TextChanged="EntryNumeric_TextChanged" />
    </VerticalStackLayout>
</ContentView>
