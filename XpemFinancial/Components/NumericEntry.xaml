<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                   xmlns:local="clr-namespace:XpemFinancial.Components"
             x:DataType="local:NumericEntry"
             x:Name="this"
             x:Class="XpemFinancial.Components.NumericEntry">
    <VerticalStackLayout>
        <Entry
            x:Name="EntryNumeric"
            MaxLength="999"
            Keyboard="Numeric"
            Style="{StaticResource Entry}"
            TextChanged="EntryNumeric_TextChanged" />
    </VerticalStackLayout>
</ContentView>
