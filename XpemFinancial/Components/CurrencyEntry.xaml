<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:XpemFinancial.Components"
             x:DataType="local:CurrencyEntry"
             x:Name="this"
             x:Class="XpemFinancial.Components.CurrencyEntry">
    <VerticalStackLayout>
        <Label Style="{StaticResource LblHEntry}" Text="{Binding Source={x:Reference this}, Path=LabelText}" />
        <Entry
                   x:Name="EntryCurrency"
                   HorizontalOptions="Fill"
                   Keyboard="Numeric"
                   Style="{StaticResource Entry}"
                   TextChanged="EntryCurrency_TextChanged" />
    </VerticalStackLayout>
</ContentView>
