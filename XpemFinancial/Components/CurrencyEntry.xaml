<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XpemFinancial.Components.CurrencyEntry"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XpemFinancial.Components"
    x:Name="this"
    x:DataType="local:CurrencyEntry">
    <VerticalStackLayout>
        <Border
            BackgroundColor="Transparent"
            HorizontalOptions="Fill"
            Stroke="{StaticResource DeleteAction}"
            StrokeShape="RoundRectangle 5"
            StrokeThickness="0"
            VerticalOptions="Fill">
            <Border.Triggers>
                <DataTrigger
                    Binding="{Binding Source={x:Reference this}, Path=IsRequired}"
                    TargetType="Border"
                    Value="True">
                    <Setter Property="StrokeThickness" Value="1" />
                </DataTrigger>
            </Border.Triggers>
            <Entry
                x:Name="EntryCurrency"
                HorizontalOptions="Fill"
                Keyboard="Numeric"
                TextChanged="EntryCurrency_TextChanged" />
        </Border>
        <Label
            Padding="0,0,0,0"
            IsVisible="{Binding Source={x:Reference this}, Path=IsRequired}"
            Text="{Binding Source={x:Reference this}, Path=RequiredText}"
            TextColor="{StaticResource DeleteAction}" />
    </VerticalStackLayout>
</ContentView>
