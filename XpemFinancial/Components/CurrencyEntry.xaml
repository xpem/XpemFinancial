<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XpemFinancial.Components.CurrencyEntry"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:XpemFinancial.Components"
    x:Name="this"
    x:DataType="local:CurrencyEntry">
    <VerticalStackLayout>
        <Entry
            x:Name="EntryCurrency"
            HorizontalOptions="Fill"
            Keyboard="Numeric"
            TextChanged="EntryCurrency_TextChanged" />
    </VerticalStackLayout>
</ContentView>
