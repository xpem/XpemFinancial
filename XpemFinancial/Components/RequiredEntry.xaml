<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="XpemFinancial.Components.RequiredEntry"
             x:Name="this"
             >
    <VerticalStackLayout>
        <Label 
            Text="{Binding Source={x:Reference this}, Path=LabelText}"
            Padding="0,10,0,0"  />
        <Border
            Stroke="{StaticResource DeleteAction}"
            StrokeThickness="{Binding Source={x:Reference this}, Path=RequiredStrokeThickness}"
            StrokeShape="RoundRectangle 5"
            BackgroundColor="Transparent"
            HorizontalOptions="Fill"
            VerticalOptions="Fill">
            <Entry Text="{Binding Source={x:Reference this}, Path=EntryValue}" IsTextPredictionEnabled="{Binding Source={x:Reference this}, Path=IsTextPredictionEnabled}"/>
        </Border>
        <Label 
            IsVisible="{Binding Source={x:Reference this}, Path=IsRequired}"
            Text="{Binding Source={x:Reference this}, Path=RequiredText}"
            TextColor="{StaticResource DeleteAction}"
            Padding="0,0,0,0"  />
    </VerticalStackLayout>
</ContentView>
