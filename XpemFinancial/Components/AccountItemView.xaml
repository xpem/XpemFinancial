<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="XpemFinancial.Components.AccountItemView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Utils="clr-namespace:XpemFinancial.Utils"
    x:Name="Root">
    <ContentView.Resources>
        <Utils:AccountTypeConverter x:Key="AccountTypeConverter" />
    </ContentView.Resources>
    <Border
        x:Name="ItemBorder"
        Padding="12"
        BackgroundColor="{StaticResource InputBackground}"
        StrokeShape="RoundRectangle 8">
        <Border.Triggers>
            <DataTrigger
                Binding="{Binding IsInactive, Source={x:Reference Root}}"
                TargetType="Border"
                Value="True">
                <Setter Property="Opacity" Value="0.6" />
            </DataTrigger>
        </Border.Triggers>
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
            <Label
                Grid.Row="0"
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="15"
                Text="{Binding AccountName, Source={x:Reference Root}}"
                TextColor="{StaticResource FontLight}" />
            <Label
                Grid.Row="0"
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="15"
                Text="{Binding AccountBalance, Source={x:Reference Root}, StringFormat='{0:C}'}"
                TextColor="{StaticResource FontLight}" />
            <HorizontalStackLayout
                Grid.Row="1"
                Grid.Column="0"
                Spacing="6">
                <Label
                    FontSize="13"
                    Text="{Binding AccountType, Source={x:Reference Root}, Converter={StaticResource AccountTypeConverter}}"
                    TextColor="{StaticResource FontDark}" />
                <Label
                    FontSize="12"
                    IsVisible="{Binding IsInactive, Source={x:Reference Root}}"
                    Text="(Inativa)"
                    TextColor="{StaticResource Expense}" />
            </HorizontalStackLayout>
        </Grid>
    </Border>
</ContentView>
