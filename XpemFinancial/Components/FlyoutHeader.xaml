<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="this"
             xmlns:Icons="clr-namespace:XpemFinancial.Resources"
             x:Class="XpemFinancial.Components.FlyoutHeader">
    <FlexLayout HorizontalOptions="Fill">
        <FlexLayout.Background>
            <LinearGradientBrush>
                <GradientStop Offset="0.1" Color="{StaticResource PageBackground}" />
                <GradientStop Offset="1.0" Color="{StaticResource BodyBackground}" />
            </LinearGradientBrush>
        </FlexLayout.Background>
        <Grid HorizontalOptions="Fill">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="6*" />
            </Grid.ColumnDefinitions>
            <Label
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                FontFamily="Icons"
                FontSize="30"
                HorizontalOptions="Center"
                Text="{x:Static Icons:IconFont.User}"
                TextColor="White"
                VerticalOptions="Center" />
            <Label
                Grid.Row="0"
                Grid.Column="1"
                FontFamily="EBGaramondRegular"
                FontSize="18"
                HorizontalOptions="Start"
                LineBreakMode="TailTruncation"
                Text="{Binding Source={x:Reference this}, Path=Name}"
                TextColor="White"
                VerticalOptions="End" />
            <Label
                Grid.Row="1"
                Grid.Column="1"
                FontFamily="EBGaramondRegular"
                FontSize="15"
                HorizontalOptions="Start"
                LineBreakMode="TailTruncation"
                Text="{Binding Source={x:Reference this}, Path=Email}"
                TextColor="White"
                VerticalOptions="Start" />
        </Grid>
    </FlexLayout>
</ContentView>
