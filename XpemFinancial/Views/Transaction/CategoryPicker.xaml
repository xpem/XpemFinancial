<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XpemFinancial.Views.CategoryPicker"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Icons="clr-namespace:XpemFinancial.Resources"
    xmlns:Models="clr-namespace:Model.DTO;assembly=Model"
    xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:utils="clr-namespace:XpemFinancial.Utils"
    xmlns:vms="clr-namespace:XpemFinancial.VMs"
    x:DataType="vms:CategoryPickerVM"
    BackgroundColor="{StaticResource BodyBackground}">
    <Shell.TitleView>
        <Grid VerticalOptions="Fill">
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label
                    FontFamily="Icons"
                    FontSize="17"
                    Text="{x:Static Icons:IconFont.Tag}"
                    TextColor="{StaticResource White}"
                    VerticalOptions="Center" />
                <Label
                    FontSize="17"
                    Text="Selecionar Categoria"
                    TextColor="{StaticResource White}"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Button
                BackgroundColor="Transparent"
                Command="{Binding AddCategoryCommand}"
                ContentLayout="Left, 6"
                FontFamily="Icons"
                FontSize="18"
                HorizontalOptions="End"
                Text="{x:Static Icons:IconFont.Plus}"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>
    <ContentPage.Resources>
        <utils:BoldConverter x:Key="BoldConverter" />
        <utils:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <!--<utils:CategoryTypeIconConverter x:Key="CategoryTypeIconConverter" />
        <utils:CategoryTypeColorConverter x:Key="CategoryTypeColorConverter" />
        <utils:IsNotNullConverter x:Key="IsNotNullConverter" />-->

        <!--  Template for parent categories that have children (expandable)  -->
        <DataTemplate x:Key="ExpandableTemplate" x:DataType="utils:CategoryGroup">
            <mct:Expander>
                <mct:Expander.Header>
                    <Grid Padding="15,12" ColumnDefinitions="*,Auto">
                        <!--<Label
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            FontFamily="Icons"
                            FontSize="13"
                            IsVisible="{Binding Parent.Type, Converter={StaticResource IsNotNullConverter}}"
                            Text="{Binding Parent.Type, Converter={StaticResource CategoryTypeIconConverter}}"
                            TextColor="{Binding Parent.Type, Converter={StaticResource CategoryTypeColorConverter}}"
                            VerticalOptions="Center" />-->
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="{Binding Parent.Name}"
                            VerticalOptions="Center" />
                        <Label
                            Grid.Column="1"
                            FontFamily="Icons"
                            FontSize="12"
                            Opacity="0.6"
                            Text="{x:Static Icons:IconFont.ChevronDown}"
                            TextColor="{StaticResource White}"
                            VerticalOptions="Center" />
                    </Grid>
                </mct:Expander.Header>
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Children}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="Models:CategoryDTO">
                            <Grid Padding="30,10,15,10">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vms:CategoryPickerVM}}, Path=SelectItemCommand}" CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                                <!--<Label
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    FontFamily="Icons"
                                    FontSize="13"
                                    IsVisible="{Binding Type, Converter={StaticResource IsNotNullConverter}}"
                                    Text="{Binding Type, Converter={StaticResource CategoryTypeIconConverter}}"
                                    TextColor="{Binding Type, Converter={StaticResource CategoryTypeColorConverter}}"
                                    VerticalOptions="Center" />-->
                                <Label
                                    FontSize="15"
                                    Text="{Binding Name}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </mct:Expander>
        </DataTemplate>

        <!--  Template for standalone categories without children (tappable)  -->
        <DataTemplate x:Key="SimpleTemplate" x:DataType="utils:CategoryGroup">
            <Grid Padding="15,12">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vms:CategoryPickerVM}}, Path=SelectItemCommand}" CommandParameter="{Binding Parent}" />
                </Grid.GestureRecognizers>
                <!--<Label
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    FontFamily="Icons"
                    FontSize="13"
                    IsVisible="{Binding Parent.Type, Converter={StaticResource IsNotNullConverter}}"
                    Text="{Binding Parent.Type, Converter={StaticResource CategoryTypeIconConverter}}"
                    TextColor="{Binding Parent.Type, Converter={StaticResource CategoryTypeColorConverter}}"
                    VerticalOptions="Center" />-->
                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="{Binding Parent.Name}"
                    VerticalOptions="Center" />
            </Grid>
        </DataTemplate>

        <utils:CategoryGroupTemplateSelector
            x:Key="GroupTemplateSelector"
            ExpandableTemplate="{StaticResource ExpandableTemplate}"
            SimpleTemplate="{StaticResource SimpleTemplate}" />
    </ContentPage.Resources>
    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0">
            <SearchBar
                x:Name="searchBar"
                IsEnabled="{Binding IsNotBusy}"
                Placeholder="Procurar..." />
            <ActivityIndicator
                Margin="0,0,15,0"
                HeightRequest="20"
                HorizontalOptions="End"
                IsRunning="{Binding IsSearching}"
                IsVisible="{Binding IsSearching}"
                VerticalOptions="Center"
                WidthRequest="20"
                Color="{StaticResource White}" />
        </Grid>

        <!--  Loading  -->
        <ActivityIndicator
            Grid.Row="1"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            Color="{StaticResource White}" />

        <!--  Accordion view (grouped with Expanders)  -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsSearchActive, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout BindableLayout.ItemTemplateSelector="{StaticResource GroupTemplateSelector}" BindableLayout.ItemsSource="{Binding CategoryGroups}">
                <BindableLayout.EmptyView>
                    <Label
                        Margin="20"
                        FontSize="15"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Text="{Binding EmptyStateMessage}"
                        TextColor="{StaticResource White}"
                        VerticalOptions="Center" />
                </BindableLayout.EmptyView>
            </VerticalStackLayout>
        </ScrollView>

        <!--  Flat search results  -->
        <CollectionView
            Grid.Row="1"
            IsVisible="{Binding IsSearchActive}"
            ItemsSource="{Binding FilteredCategories}"
            SelectionMode="None">
            <CollectionView.EmptyView>
                <Label
                    Margin="20"
                    FontSize="15"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="Nenhum resultado encontrado"
                    TextColor="{StaticResource White}"
                    VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="Models:CategoryDTO">
                    <Grid Padding="15">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vms:CategoryPickerVM}}, Path=SelectItemCommand}" CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <!--<Label
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            FontFamily="Icons"
                            FontSize="13"
                            IsVisible="{Binding Type, Converter={StaticResource IsNotNullConverter}}"
                            Text="{Binding Type, Converter={StaticResource CategoryTypeIconConverter}}"
                            TextColor="{Binding Type, Converter={StaticResource CategoryTypeColorConverter}}"
                            VerticalOptions="Center" />-->
                        <Label
                            FontAttributes="{Binding IsMainCategory, Converter={StaticResource BoldConverter}}"
                            FontSize="16"
                            Text="{Binding Name}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
