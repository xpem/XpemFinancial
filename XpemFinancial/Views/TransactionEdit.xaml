<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="XpemFinancial.Views.TransactionEdit"
             Shell.BackgroundColor="{StaticResource Inflow}"
             Shell.TitleColor="{StaticResource Black}"
             BackgroundColor="{StaticResource PageBackgroundColor}"
             
             Title="Adicionar transação">
    <ScrollView Margin="10">
        <VerticalStackLayout>
            <HorizontalStackLayout  RadioButtonGroup.GroupName="TransactionType"   
                                    Padding="0,5,0,0" 
                                    BackgroundColor="{StaticResource HeaderBackgroundColor}">
                <RadioButton Content="Despesa" IsChecked="True" Margin="10,0" />
                <RadioButton Content="Receita" IsChecked="False" Margin="10,0" />
                <RadioButton Content="Transferencia" IsChecked="False" Margin="10,0" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>