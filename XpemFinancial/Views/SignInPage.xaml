<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XpemFinancial.Views.SignInPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Components="clr-namespace:XpemFinancial.Components"
    xmlns:Icons="clr-namespace:XpemFinancial.Resources"
    xmlns:Utils="clr-namespace:XpemFinancial.Utils"
    xmlns:vms="clr-namespace:XpemFinancial.VMs"
    Title="SignIn"
    x:DataType="vms:SignInVM"
    NavigationPage.HasNavigationBar="False"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False" IsVisible="False" />
    </Shell.BackButtonBehavior>
    <ContentPage.Resources>
        <Style x:Key="Icon" TargetType="Label">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="FontSize" Value="70" />
            <Setter Property="FontFamily" Value="Icons" />
            <Setter Property="Padding" Value="0,0,0,10" />
        </Style>
    </ContentPage.Resources>
    <VerticalStackLayout Margin="10" VerticalOptions="Center">
        <Label
            SemanticProperties.Description="Imagem da tela inicial do sistema"
            Style="{StaticResource Icon}"
            Text="{x:Static Icons:IconFont.SackDollar}" />
        <Components:RequiredEntry
            EntryValue="{Binding Email}"
            IsRequired="{Binding IsRequired}"
            LabelText="Email" />
        <Components:RequiredEntry
            EntryValue="{Binding Password}"
            IsPassword="True"
            IsRequired="{Binding IsRequired}"
            LabelText="Senha" />

        <Button
            Margin="0,10,0,20"
            Command="{Binding SignInCommand}"
            ContentLayout="Left, 10"
            IsEnabled="{Binding BtnSignEnabled}"
            SemanticProperties.Description="{Binding SignInText}"
            SemanticProperties.Hint="Botão para acessar com usuário e senha"
            Style="{StaticResource SuccessButton}"
            Text="{Binding SignInText}">
            <Button.ImageSource>
                <FontImageSource
                    FontFamily="Icons"
                    Glyph="{x:Static Icons:IconFont.ArrowRightToBracket}"
                    Size="15"
                    Color="White" />
            </Button.ImageSource>
        </Button>
        <Label
            IsVisible="{Binding ErrorMessageIsVisible}"
            Text="{Binding ErrorMessage}"
            TextColor="{StaticResource DeleteAction}" />
        <HorizontalStackLayout>
            <Label
                Margin="0,0,5,0"
                Text="Não tem conta?"
                TextColor="{StaticResource Gray100}" />
            <Label
                HorizontalOptions="Start"
                SemanticProperties.Description="Criar Conta"
                SemanticProperties.Hint="Acessar criação de conta"
                Text="Criar Conta"
                TextColor="{StaticResource PrimaryAction}"
                TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CreateUserCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>
        <HorizontalStackLayout Margin="0,10,0,0">
            <Label
                Margin="0,0,5,0"
                FontFamily="EBGaramondBold"
                Text="Esqueceu sua senha?"
                TextColor="{StaticResource Gray100}" />
            <Label
                FontFamily="EBGaramondBold"
                HorizontalOptions="Start"
                SemanticProperties.Description="Atualizar senha"
                SemanticProperties.Hint="Acessar atualização de senha"
                Text="Atualizar senha"
                TextColor="{StaticResource PrimaryAction}"
                TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding UpdatePasswordCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>
        <Grid Margin="0,5,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label
                Margin="0,0,0,10"
                FontFamily="OpenSansSemibold"
                FontSize="12"
                SemanticProperties.Description="Versão"
                Text="{Binding Version}"
                VerticalOptions="End" />
            <Label
                Grid.Row="0"
                Grid.Column="1"
                Margin="0,20,0,0"
                FontAttributes="Italic"
                FontFamily="OpenSansRegular"
                FontSize="10"
                HorizontalOptions="End"
                Text="@Emanuel Martins"
                TextColor="{StaticResource Gray100}"
                VerticalOptions="End" />
        </Grid>
    </VerticalStackLayout>
</ContentPage>