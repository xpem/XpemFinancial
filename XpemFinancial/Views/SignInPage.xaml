<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="XpemFinancial.Views.SignInPage"
             xmlns:Icons="clr-namespace:XpemFinancial.Resources"  
             xmlns:Utils="clr-namespace:XpemFinancial.Utils"
             xmlns:vms="clr-namespace:XpemFinancial.VMs"
             xmlns:Components="clr-namespace:XpemFinancial.Components"
             x:DataType="vms:SignInVM"
             NavigationPage.HasNavigationBar="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.NavBarIsVisible="False"
             Title="SignIn">
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False" IsVisible="False" />
    </Shell.BackButtonBehavior>
    <ContentPage.Resources>
        <Style x:Key="Icon" TargetType="Label">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="FontSize" Value="70" />
            <Setter Property="FontFamily" Value="Icons" />
            <Setter Property="Padding" Value="0,0,0,10" />
        </Style>
    </ContentPage.Resources>
    <VerticalStackLayout>
        <ScrollView Margin="10">
            <Border
                IsEnabled="{Binding IsNotBusy}"
                Style="{StaticResource BorderPrimary}"
                VerticalOptions="Center">
                <VerticalStackLayout>
                    <Label
                        SemanticProperties.Description="Imagem da tela inicial do sistema"
                        Style="{StaticResource Icon}"
                        Text="{x:Static Icons:IconFont.SackDollar}"
                        />
                    
                    <Components:RequiredEntry
                        LabelText="Email"
                        EntryValue="{Binding Email}" />
                    <Components:RequiredEntry
                        IsPassword="True"
                        LabelText="Senha"
                        EntryValue="{Binding Password}" />
                    
                    <Button
                        Margin="0,10,0,20"
                        Command="{Binding SignInCommand}"
                        ContentLayout="Left, 10"
                        IsEnabled="{Binding BtnSignEnabled}"
                        SemanticProperties.Description="{Binding SignInText}"
                        SemanticProperties.Hint="Botão para acessar com usuário e senha"
                        Style="{StaticResource BtnPrimary}"
                        Text="{Binding SignInText}">
                        <Button.ImageSource>
                            <FontImageSource
                                FontFamily="FontAwesome"
                                Glyph="{x:Static Icons:IconFont.ArrowRightToBracket}"
                                Size="15"
                                Color="Black" />
                        </Button.ImageSource>
                    </Button>
                    <HorizontalStackLayout>
                        <Label
                            Margin="0,0,5,0"
                            Text="Não tem conta?"
                            TextColor="{StaticResource Gray100}" />
                        <Label
                            HorizontalOptions="Start"
                            SemanticProperties.Description="Criar Conta"
                            SemanticProperties.Hint="Acessar criação de conta"
                            Text="Criar Conta"
                            TextColor="{StaticResource PrimaryColor}"
                            TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CreateUserCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Margin="0,10,0,0">
                        <Label
                            Margin="0,0,5,0"
                            FontFamily="EBGaramondBold"
                            Text="Esqueceu sua senha?"
                            TextColor="{StaticResource Gray100}" />
                        <Label
                            FontFamily="EBGaramondBold"
                            HorizontalOptions="Start"
                            SemanticProperties.Description="Atualizar senha"
                            SemanticProperties.Hint="Acessar atualização de senha"
                            Text="Atualizar senha"
                            TextColor="{StaticResource PrimaryColor}"
                            TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding UpdatePasswordCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                    <Grid
                        Margin="0,5,0,0" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label
                            Margin="0,0,0,10"
                            FontFamily="OpenSansSemibold"
                            FontSize="12"
                            SemanticProperties.Description="Versão"
                            Text="{Binding Version}"
                            VerticalOptions="End" />
                        <Label
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,20,0,0"
                            FontAttributes="Italic"
                            FontFamily="OpenSansRegular"
                            FontSize="10"
                            HorizontalOptions="End"
                            Text="@Emanuel Martins"
                            TextColor="{StaticResource Gray100}"
                            VerticalOptions="End" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>