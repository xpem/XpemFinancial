<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XpemFinancial.Views.ChartPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Icons="clr-namespace:XpemFinancial.Resources"
    xmlns:Utils="clr-namespace:XpemFinancial.Utils"
    xmlns:dto="clr-namespace:Model.DTO;assembly=Model"
    xmlns:vms="clr-namespace:XpemFinancial.VMs"
    x:DataType="vms:ChartVM"
    Shell.FlyoutBehavior="Flyout">

    <Shell.TitleView>
        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
            <Label
                FontFamily="Icons"
                FontSize="17"
                Text="{x:Static Icons:IconFont.ChartColumn}"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
            <Label
                FontSize="17"
                Text="Gráfico"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Shell.TitleView>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Utils:AmountToColorConverter x:Key="AmountToColorConverter" />
            <Utils:IsRecurringConverter x:Key="IsRecurringConverter" />
            <Utils:IsFutureDateConverter x:Key="IsFutureDateConverter" />

            <Style x:Key="NavButton" TargetType="Button">
                <Setter Property="BorderColor" Value="#9da9b9" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="HeightRequest" Value="20" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Margin="0">
        <VerticalStackLayout Padding="10" Spacing="10">

            <Grid ColumnDefinitions="*,*">
                <HorizontalStackLayout Margin="0,0,0,0">
                    <Button Command="{Binding LoadPreviousPeriodCommand}" Style="{StaticResource NavButton}">
                        <Button.ImageSource>
                            <FontImageSource
                                FontFamily="Icons"
                                Glyph="{x:Static Icons:IconFont.CaretLeft}"
                                Size="20" />
                        </Button.ImageSource>
                    </Button>
                    <Border Margin="5,0" Stroke="#9da9b9">
                        <Label
                            Margin="10"
                            HeightRequest="20"
                            Text="{Binding MonthYearDisplay}"
                            TextColor="#d6e0eb" />
                    </Border>
                    <Button Command="{Binding LoadNextPeriodCommand}" Style="{StaticResource NavButton}">
                        <Button.ImageSource>
                            <FontImageSource
                                FontFamily="Icons"
                                Glyph="{x:Static Icons:IconFont.CaretRight}"
                                Size="20" />
                        </Button.ImageSource>
                    </Button>
                </HorizontalStackLayout>
                <HorizontalStackLayout
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    HorizontalOptions="Center"
                    Spacing="0">
                    <Button
                        BorderColor="#9da9b9"
                        BorderWidth="1"
                        Command="{Binding SetScopeCommand}"
                        CommandParameter="{x:Boolean False}"
                        CornerRadius="0"
                        FontSize="13"
                        HeightRequest="30"
                        Text="Mensal"
                        TextColor="#d6e0eb">
                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding IsAnnualMode}"
                                TargetType="Button"
                                Value="False">
                                <Setter Property="BackgroundColor" Value="#2b3548" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding IsAnnualMode}"
                                TargetType="Button"
                                Value="True">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button
                        BorderColor="#9da9b9"
                        BorderWidth="1"
                        Command="{Binding SetScopeCommand}"
                        CommandParameter="{x:Boolean True}"
                        CornerRadius="0"
                        FontSize="13"
                        HeightRequest="30"
                        Text="Anual"
                        TextColor="#d6e0eb">
                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding IsAnnualMode}"
                                TargetType="Button"
                                Value="True">
                                <Setter Property="BackgroundColor" Value="#2b3548" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding IsAnnualMode}"
                                TargetType="Button"
                                Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </HorizontalStackLayout>
            </Grid>

            <!--  Loading indicator  -->
            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#2bbf69" />

            <!--  Include previous balance  -->
            <HorizontalStackLayout Spacing="0" VerticalOptions="Center">
                <HorizontalStackLayout.Triggers>
                    <DataTrigger
                        Binding="{Binding IsAnnualMode}"
                        TargetType="HorizontalStackLayout"
                        Value="True">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </HorizontalStackLayout.Triggers>
                <CheckBox IsChecked="{Binding IncludePreviousBalance}" Color="White" />
                <Label
                    Text="Incluir saldo anterior"
                    TextColor="#d6e0eb"
                    VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleIncludePreviousBalanceCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <!--  Accumulated vs month-by-month (annual mode only)  -->
            <HorizontalStackLayout Spacing="0" VerticalOptions="Center">
                <HorizontalStackLayout.Triggers>
                    <DataTrigger
                        Binding="{Binding IsAnnualMode}"
                        TargetType="HorizontalStackLayout"
                        Value="False">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </HorizontalStackLayout.Triggers>
                <CheckBox IsChecked="{Binding IsAnnualCumulative}" Color="White" />
                <Label
                    Text="Valores acumulados"
                    TextColor="#d6e0eb"
                    VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleAnnualCumulativeCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <Border>
                <!--  Chart canvas  -->
                <GraphicsView
                    x:Name="ChartCanvas"
                    HeightRequest="320"
                    HorizontalOptions="Fill" />
            </Border>
            <!--  Legend  -->
            <HorizontalStackLayout Spacing="16">
                <HorizontalStackLayout Spacing="6">
                    <BoxView
                        CornerRadius="2"
                        HeightRequest="10"
                        VerticalOptions="Center"
                        WidthRequest="20"
                        Color="#2bbf69" />
                    <Label
                        FontSize="12"
                        TextColor="#d6e0eb"
                        VerticalOptions="Center">
                        <Label.Triggers>
                            <MultiTrigger TargetType="Label">
                                <MultiTrigger.Conditions>
                                    <BindingCondition Binding="{Binding IsAnnualMode}" Value="True" />
                                    <BindingCondition Binding="{Binding IsAnnualCumulative}" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Text" Value="Entradas" />
                            </MultiTrigger>
                        </Label.Triggers>
                        <Label.Style>
                            <Style TargetType="Label">
                                <Setter Property="Text" Value="Entradas acumuladas" />
                            </Style>
                        </Label.Style>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <BoxView
                        CornerRadius="2"
                        HeightRequest="10"
                        VerticalOptions="Center"
                        WidthRequest="20"
                        Color="#f75c5c" />
                    <Label
                        FontSize="12"
                        TextColor="#d6e0eb"
                        VerticalOptions="Center">
                        <Label.Triggers>
                            <MultiTrigger TargetType="Label">
                                <MultiTrigger.Conditions>
                                    <BindingCondition Binding="{Binding IsAnnualMode}" Value="True" />
                                    <BindingCondition Binding="{Binding IsAnnualCumulative}" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Text" Value="Saídas" />
                            </MultiTrigger>
                        </Label.Triggers>
                        <Label.Style>
                            <Style TargetType="Label">
                                <Setter Property="Text" Value="Saídas acumuladas" />
                            </Style>
                        </Label.Style>
                    </Label>
                </HorizontalStackLayout>
            </HorizontalStackLayout>

            <!--  Saldo Geral  -->
            <!--<Border
                Padding="10"
                Stroke="#232c39"
                StrokeShape="5">
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label
                        FontFamily="Icons"
                        FontSize="15"
                        Text="{x:Static Icons:IconFont.Wallet}"
                        TextColor="#6cc8ef"
                        VerticalOptions="Center" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="Saldo Geral:"
                        TextColor="#d6e0eb"
                        VerticalOptions="Center" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="Large"
                        Text="{Binding GeneralBalance, StringFormat='{}{0:N2}'}"
                        TextColor="{StaticResource Income}"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>-->

            <!--  Top 10 Maiores Despesas  -->
            <Border
                Margin="0,5,0,0"
                Padding="0"
                Stroke="#232c39"
                StrokeShape="5">
                <Grid RowDefinitions="Auto, *">

                    <!--  Header  -->
                    <Label
                        Padding="10"
                        BackgroundColor="#232c39"
                        FontAttributes="Bold"
                        FontSize="20"
                        Text="Top 10 Maiores Despesas"
                        TextColor="#d6e0eb" />

                    <!--  List  -->
                    <CollectionView
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        ItemsSource="{Binding TopExpenses}"
                        SelectedItem="{Binding SelectedTransaction}"
                        SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:TransactionDTO">
                                <Grid
                                    Padding="5,0,5,0"
                                    ColumnDefinitions="2*, 1.2*, 1*, Auto"
                                    RowSpacing="0"
                                    VerticalOptions="Center">
                                    <Label
                                        LineBreakMode="TailTruncation"
                                        Text="{Binding Description}"
                                        TextColor="#d6e0eb"
                                        VerticalOptions="Center" />
                                    <Label
                                        Grid.Column="1"
                                        FontAttributes="{Binding Date, Converter={StaticResource IsFutureDateConverter}}"
                                        HorizontalTextAlignment="Center"
                                        Text="{Binding Date, StringFormat='{0:dd/MM}'}"
                                        TextColor="#d6e0eb"
                                        VerticalOptions="Center" />
                                    <Label
                                        Grid.Column="2"
                                        FontAttributes="Bold"
                                        HorizontalTextAlignment="End"
                                        Text="{Binding Amount, StringFormat='{0:N2}'}"
                                        TextColor="{Binding Amount, Converter={StaticResource AmountToColorConverter}}"
                                        VerticalOptions="Center" />
                                    <Image
                                        Grid.Column="3"
                                        Margin="4,0,0,0"
                                        HeightRequest="12"
                                        IsVisible="{Binding RecurringRuleId, Converter={StaticResource IsRecurringConverter}}"
                                        VerticalOptions="Center"
                                        WidthRequest="12">
                                        <Image.Source>
                                            <FontImageSource
                                                FontFamily="Icons"
                                                Glyph="{x:Static Icons:IconFont.ArrowsRotate}"
                                                Size="12"
                                                Color="#6cc8ef" />
                                        </Image.Source>
                                    </Image>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label
                                Margin="20"
                                HorizontalOptions="Center"
                                Text="Nenhuma despesa encontrada para o período selecionado."
                                TextColor="#758292" />
                        </CollectionView.EmptyView>
                    </CollectionView>

                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
