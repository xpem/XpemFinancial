<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XpemFinancial.Views.TransactionEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Components="clr-namespace:XpemFinancial.Components"
    xmlns:Icons="clr-namespace:XpemFinancial.Resources"
    xmlns:Utils="clr-namespace:XpemFinancial.Utils"
    xmlns:model="clr-namespace:Model.DTO;assembly=Model"
    xmlns:req="clr-namespace:Model.Req;assembly=Model"
    xmlns:res="clr-namespace:Model.Res;assembly=Model"
    xmlns:vms="clr-namespace:XpemFinancial.VMs"
    x:Name="this"
    x:DataType="vms:TransactionEditVM"
    BackgroundColor="{StaticResource BodyBackground}"
    Shell.BackgroundColor="{Binding TransactionTypeColor}"
    Shell.TitleColor="{StaticResource White}">
    <Shell.TitleView>
        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
            <Label
                FontFamily="Icons"
                FontSize="17"
                Text="{Binding TitleIcon}"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
            <Label
                FontSize="17"
                Text="{Binding PageTitle}"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Shell.TitleView>
    <ContentPage.Resources>
        <Utils:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <Style x:Key="RadioButton" TargetType="RadioButton">
            <Setter Property="TextColor" Value="#d6e0eb" />
            <Setter Property="BorderColor" Value="#d6e0eb" />
            <Setter Property="ControlTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Grid
                                HeightRequest="20"
                                VerticalOptions="Center"
                                WidthRequest="20">
                                <Ellipse
                                    Fill="Transparent"
                                    Stroke="#d6e0eb"
                                    StrokeThickness="2" />
                                <Ellipse
                                    x:Name="checkedDot"
                                    Fill="#d6e0eb"
                                    HeightRequest="10"
                                    HorizontalOptions="Center"
                                    IsVisible="False"
                                    VerticalOptions="Center"
                                    WidthRequest="10" />
                            </Grid>
                            <ContentPresenter VerticalOptions="Center" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CheckedStates">
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter TargetName="checkedDot" Property="Ellipse.IsVisible" Value="True" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Unchecked">
                                            <VisualState.Setters>
                                                <Setter TargetName="checkedDot" Property="Ellipse.IsVisible" Value="False" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </HorizontalStackLayout>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ContentPage.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ScrollView Margin="10">
            <VerticalStackLayout>
                <Border Margin="0,0,0,10" Padding="0,5,0,0">
                    <HorizontalStackLayout RadioButtonGroup.GroupName="TransactionType" RadioButtonGroup.SelectedValue="{Binding SelectedTransactionType}">
                        <RadioButton
                            Margin="10,0"
                            Content="Despesa"
                            IsChecked="True"
                            Style="{StaticResource RadioButton}"
                            Value="{x:Static model:TransactionType.Expense}" />
                        <RadioButton
                            Margin="10,0"
                            Content="Receita"
                            IsChecked="False"
                            Style="{StaticResource RadioButton}"
                            Value="{x:Static model:TransactionType.Income}" />
                        <RadioButton
                            Margin="10,0"
                            Content="Transferência"
                            IsChecked="False"
                            Style="{StaticResource RadioButton}"
                            Value="{x:Static model:TransactionType.Transfer}" />
                    </HorizontalStackLayout>
                </Border>
                <Grid ColumnDefinitions="auto, auto">
                    <VerticalStackLayout>
                        <Label Text="Data" />
                        <Border>
                            <DatePicker
                                x:Name="DataDtPkr"
                                BackgroundColor="{StaticResource InputBackground}"
                                Date="{Binding TransactionDate, Mode=TwoWay}"
                                Format="dd/MM/yyyy"
                                MaximumDate="01/01/2100"
                                MinimumDate="01/01/1990" />
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        IsVisible="{Binding IsTransfer, Converter={StaticResource InvertedBoolConverter}}">
                        <Label FontSize="14" Text="Categoria" />
                        <Border Padding="10" BackgroundColor="{StaticResource InputBackground}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenCategoryPickerCommand}" />
                            </Border.GestureRecognizers>

                            <HorizontalStackLayout>
                                <Label
                                    FontSize="17"
                                    Text="{Binding SelectedCategoryName, TargetNullValue='Selecionar Categoria'}"
                                    VerticalOptions="Center" />
                                <Label
                                    Margin="10,0,0,0"
                                    FontFamily="Icons"
                                    FontSize="15"
                                    Text="{x:Static Icons:IconFont.AngleRight}"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
                <Components:RequiredEntry
                    x:Name="DescriptionEntry"
                    EntryValue="{Binding Description}"
                    IsRequired="False"
                    IsTextPredictionEnabled="True"
                    LabelText="Descrição"
                    SizeChanged="OnDescriptionEntrySizeChanged" />

                <Grid
                    Grid.Column="2"
                    Padding="0,10,0,0"
                    ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                    <VerticalStackLayout>
                        <Label Text="Valor" />
                        <Components:CurrencyEntry Text="{Binding Amount}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Conta" />
                        <Border
                            Padding="0"
                            BackgroundColor="{StaticResource InputBackground}"
                            StrokeShape="RoundRectangle 5">
                            <Picker
                                ItemDisplayBinding="{Binding Name}"
                                ItemsSource="{Binding ActiveAccounts}"
                                SelectedItem="{Binding SelectedAccount}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
                <!--  Conta destino — visível apenas para transferências  -->
                <VerticalStackLayout Padding="0,10,0,0" IsVisible="{Binding IsTransfer}">
                    <Label Text="Conta destino" />
                    <Border
                        Padding="0"
                        BackgroundColor="{StaticResource InputBackground}"
                        StrokeShape="RoundRectangle 5">
                        <Picker
                            ItemDisplayBinding="{Binding Name}"
                            ItemsSource="{Binding DestinationAccounts}"
                            SelectedItem="{Binding SelectedDestinationAccount}" />
                    </Border>
                </VerticalStackLayout>
                <Border
                    Margin="0,10,0,10"
                    Padding="0,5,0,0"
                    IsVisible="{Binding IsTransfer, Converter={StaticResource InvertedBoolConverter}}">
                    <HorizontalStackLayout
                        x:Name="Repetition"
                        HorizontalOptions="Start"
                        IsEnabled="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                        RadioButtonGroup.GroupName="Repetition"
                        RadioButtonGroup.SelectedValue="{Binding SelectedRepetition}">
                        <RadioButton
                            Margin="10,0"
                            Content="Única"
                            IsChecked="True"
                            Style="{StaticResource RadioButton}"
                            Value="{x:Static model:Repetition.None}" />
                        <RadioButton
                            Margin="10,0"
                            Content="Parcelada"
                            IsChecked="False"
                            Style="{StaticResource RadioButton}"
                            Value="{x:Static model:Repetition.Monthly}" />
                        <RadioButton
                            Margin="10,0"
                            Content="Recorrente"
                            IsChecked="False"
                            Style="{StaticResource RadioButton}"
                            Value="{x:Static model:Repetition.Recurring}" />
                    </HorizontalStackLayout>
                </Border>
                <HorizontalStackLayout x:Name="InstallmentPanel" IsVisible="{Binding InstallmentPanelIsVisible}">
                    <Label
                        Margin="0,0,10,0"
                        Text="Parcelas de"
                        VerticalOptions="Center" />
                    <Components:NumericEntry Text="{Binding InitialInstallments}" VerticalOptions="Center" />
                    <Label
                        Margin="10,0"
                        Text="até"
                        VerticalOptions="Center" />
                    <Components:NumericEntry Text="{Binding NumberOfInstallments}" VerticalOptions="Center" />
                    <Label
                        Margin="10,0"
                        Text="Total restante:"
                        VerticalOptions="Center" />
                    <Label
                        FontAttributes="Bold"
                        Text="{Binding TotalAmountInstallments}"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
                <!--  Escopo de edição — visível apenas ao editar ocorrência recorrente  -->
                <Border
                    Margin="0,10,0,0"
                    Padding="10"
                    IsVisible="{Binding IsRecurring}"
                    Stroke="{StaticResource PrimaryAction}">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="Editar recorrência"
                            TextColor="{StaticResource White}" />
                        <HorizontalStackLayout RadioButtonGroup.GroupName="EditScope" RadioButtonGroup.SelectedValue="{Binding SelectedEditScope}">
                            <RadioButton
                                Margin="0,0,16,0"
                                Content="Só esta"
                                Style="{StaticResource RadioButton}"
                                Value="{x:Static req:EditScope.ThisOnly}" />
                            <RadioButton
                                Margin="0,0,16,0"
                                Content="Esta e futuras"
                                Style="{StaticResource RadioButton}"
                                Value="{x:Static req:EditScope.ThisAndFuture}" />
                            <RadioButton
                                Content="Todas"
                                Style="{StaticResource RadioButton}"
                                Value="{x:Static req:EditScope.All}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Label Padding="0,10,0,0" Text="Notas" />
                <Editor HeightRequest="100" Text="{Binding Note}" />
            </VerticalStackLayout>
        </ScrollView>

        <!--  Dismiss layer: sits above the ScrollView (z=2). Tapping anywhere outside the suggestion list dismisses it.  -->
        <BoxView
            Grid.Row="0"
            BackgroundColor="Transparent"
            InputTransparent="False"
            IsVisible="{Binding SuggestionsVisible}">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissSuggestionsCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Button
            x:Name="CreateTransactionButton"
            Margin="0,0,10,10"
            BackgroundColor="{Binding TransactionTypeColor}"
            Command="{Binding SaveTransactionCommand}"
            ContentLayout="Left, 10"
            CornerRadius="5"
            HorizontalOptions="End"
            Style="{StaticResource SuccessButton}"
            Text="Confirmar"
            TextColor="White"
            VerticalOptions="End">
            <Button.ImageSource>
                <FontImageSource
                    FontFamily="Icons"
                    Glyph="{x:Static Icons:IconFont.Check}"
                    Size="13"
                    Color="White" />
            </Button.ImageSource>
            <!--<Button.Triggers>
                <DataTrigger
                    Binding="{Binding IsEditing}"
                    TargetType="Button"
                    Value="True">
                    <Setter Property="Style" Value="{StaticResource UpdateButton}" />
                    <Setter Property="ImageSource">
                        <Setter.Value>
                            <FontImageSource
                                FontFamily="Icons"
                                Glyph="{x:Static Icons:IconFont.Pen}"
                                Color="#121b27" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Button.Triggers>-->
        </Button>
        <!--
            Suggestion list floats above the dismiss BoxView (declared last = highest z-order).
            It is positioned at the top of the grid and sized to show only the list items,
            so taps outside its bounds hit the BoxView and dismiss it.
        -->
        <CollectionView
            x:Name="ListaSugestoes"
            Grid.Row="0"
            BackgroundColor="{StaticResource InputBackground}"
            IsVisible="{Binding SuggestionsVisible}"
            ItemsSource="{Binding DescriptionSuggestions}"
            MaximumHeightRequest="200"
            SelectionChanged="OnSugestaoSelected"
            SelectionMode="Single"
            VerticalOptions="Start">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="res:TransactionDescriptionRes">
                    <Grid Padding="10,8">
                        <Label
                            FontSize="15"
                            Text="{Binding Description}"
                            TextColor="White" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>