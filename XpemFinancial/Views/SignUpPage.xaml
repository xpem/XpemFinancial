<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XpemFinancial.Views.SignUpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Components="clr-namespace:XpemFinancial.Components"
    xmlns:Icons="clr-namespace:XpemFinancial.Resources"
    xmlns:Utils="clr-namespace:XpemFinancial.Utils"
    xmlns:vms="clr-namespace:XpemFinancial.VMs"
    Title="Cadastrar Usuário"
    x:DataType="vms:SignUpVM"
    Shell.FlyoutBehavior="Disabled"
    Style="{StaticResource ContentPage}">
    <ContentPage.Resources>
        <Style x:Key="Icon" TargetType="Label">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="FontSize" Value="40" />
            <Setter Property="FontFamily" Value="FontAwesome" />
            <Setter Property="Padding" Value="0,0,0,10" />
        </Style>
    </ContentPage.Resources>
    <VerticalStackLayout Margin="10" VerticalOptions="Center">
        <Label
            FontFamily="Icons"
            SemanticProperties.Description="Imagem da tela inicial do sistema"
            Style="{StaticResource Icon}"
            Text="{x:Static Icons:IconFont.User}" />
        <Components:RequiredEntry
            EntryValue="{Binding Name}"
            IsRequired="{Binding IsRequired}"
            LabelText="Nome" />
        <Components:RequiredEntry
            EntryValue="{Binding Email}"
            IsRequired="{Binding IsRequired}"
            LabelText="Email" />
        <Components:RequiredEntry
            EntryValue="{Binding Password}"
            IsPassword="True"
            IsRequired="{Binding IsRequired}"
            LabelText="Senha" />
        <Components:RequiredEntry
            EntryValue="{Binding ConfirmPassword}"
            IsPassword="True"
            IsRequired="{Binding IsRequired}"
            LabelText="Confirmar Senha" />
        <Button
            Margin="0,10,0,20"
            Command="{Binding SignUpCommand}"
            ContentLayout="Left, 10"
            IsEnabled="{Binding BtnSignUpEnabled}"
            SemanticProperties.Description="Criar usuário"
            SemanticProperties.Hint="Botão para cadastrar um novo usuário"
            Style="{StaticResource SuccessButton}"
            Text="Cadastrar">
            <Button.ImageSource>
                <FontImageSource
                    FontFamily="Icons"
                    Glyph="{x:Static Icons:IconFont.UserPlus}"
                    Size="15"
                    Color="White" />
            </Button.ImageSource>
        </Button>
        <Label
            IsVisible="{Binding ErrorMessageIsVisible}"
            Text="{Binding ErrorMessage}"
            TextColor="{StaticResource DeleteAction}" />
    </VerticalStackLayout>
</ContentPage>