<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:Icons="clr-namespace:XpemFinancial.Resources"  
             xmlns:Utils="clr-namespace:XpemFinancial.Utils"
             xmlns:ViewModels="clr-namespace:XpemFinancial.VMs" x:DataType="ViewModels:MainPageVM"
             BackgroundColor="{StaticResource PageBackground}"
             x:Class="XpemFinancial.Views.MainPage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Utils:AmountToColorConverter x:Key="AmountToColorConverter" />
        </ResourceDictionary>
        <Style x:Key="btnDefault" TargetType="Button">
            <Setter Property="BorderColor" Value="#9da9b9" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HeightRequest" Value="20" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <!--<Setter Property="" Value="" />-->

        </Style>
        <Style x:Key="btnPrimary" TargetType="Button">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HeightRequest" Value="20" />
            <Setter Property="BackgroundColor" Value="{StaticResource Inflow}" />
            <Setter Property="TextColor" Value="#121b27" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontAttributes" Value="Bold" />
            <!--<Setter Property="" Value="" />-->

        </Style>
    </ContentPage.Resources>
    <ScrollView Margin="10">
        <VerticalStackLayout BackgroundColor="#181f2a" Padding="5">
            <FlexLayout Wrap="Wrap" Direction="Row" AlignItems="Center">
                <Button x:Name="PreviousMonthButton" Style="{StaticResource btnDefault}">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="Icons"
                                         Glyph="{x:Static Icons:IconFont.CaretLeft}"/>
                    </Button.ImageSource>
                </Button>
                <Border Margin="5,10,5,10" Stroke="#9da9b9">
                    <Label Text="Agosto/2026" Margin="10,10,10,10" HeightRequest="20"  TextColor="#d6e0eb" />
                </Border>
                <Button x:Name="NextMonthButton" Style="{StaticResource btnDefault}" Margin="0,0,10,0">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="Icons"
                                       Glyph="{x:Static Icons:IconFont.CaretRight}"/>
                    </Button.ImageSource>
                </Button>
                <Button x:Name="CreateTransaction" Style="{StaticResource btnPrimary}" ContentLayout="Left, 10" Text="Adicionar transação" Command="{Binding GoToTransactionEditCommand}">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="Icons" Color="#121b27"
                                         Glyph="{x:Static Icons:IconFont.Plus}"/>
                    </Button.ImageSource>
                </Button>
            </FlexLayout>
            <Border Stroke="#232c39" StrokeShape="5" Margin="10" Padding="0" >
                <Grid RowDefinitions="Auto, *,*">
                    <!-- Header Section -->
                    <Label Text="Entradas e saídas" 
                           FontAttributes="Bold" 
                           FontSize="Header" 
                           TextColor="#d6e0eb"
                           BackgroundColor="#232c39" 
                           Padding="10"
                           />
                    <!-- Content Section -->
                    <HorizontalStackLayout Spacing="0" 
                       Grid.Row="1" 
                       VerticalOptions="Center">

                        <CheckBox x:Name="CheckBoxIncludePreviousBalance"
                                  Color="White"
                                  IsChecked="{Binding Totals.IncludePreviousBalance}" />

                        <Label Text="Incluir saldo anterior" 
                               TextColor="#d6e0eb"                                     
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleIncludePreviousBalanceCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </HorizontalStackLayout>
                    <Grid Grid.Row="2" ColumnDefinitions="*, *" 
                          HorizontalOptions="Fill" Padding="5"
                          RowDefinitions="Auto, Auto, Auto, Auto, Auto">

                        <Label Text="Saldo anterior" FontAttributes="Bold" TextColor="#d6e0eb" VerticalTextAlignment="Center" IsVisible="{Binding Totals.IncludePreviousBalance}"/>
                        <Label Grid.Column="1" Text="{Binding Totals.PreviousBalance, StringFormat='{}{0:C}'}" FontSize="Large" TextColor="#6cc8ef" HorizontalOptions="End" IsVisible="{Binding Totals.IncludePreviousBalance}"/>

                        <Label Grid.Row="1" Text="Entradas" FontAttributes="Bold" TextColor="{StaticResource Inflow}" VerticalTextAlignment="Center"/>
                        <Label Grid.Row="1" Grid.Column="1"  Text="{Binding Totals.Inflow, StringFormat='{}{0:C}'}" FontSize="Large" TextColor="{StaticResource Inflow}" HorizontalOptions="End"/>
                        <Label Grid.Row="2" Text="Saídas" FontAttributes="Bold" TextColor="#d6e0eb" VerticalTextAlignment="Center"/>
                        <Label Grid.Row="2" Grid.Column="1"  Text="{Binding Totals.Outflow, StringFormat='{}{0:C}'}" FontSize="Large" TextColor="#f75c5c" HorizontalOptions="End"/>

                        <!--total separado por uma linha-->
                        <BoxView Grid.Row="3" Grid.ColumnSpan="2" HeightRequest="1" BackgroundColor="#6cc8ef" Margin="0,10,0,10"/>
                        <Label Grid.Row="4" Grid.ColumnSpan="2" Text="{Binding Totals.Total, StringFormat='{}{0:C}'}" FontAttributes="Bold" TextColor="#d6e0eb" VerticalTextAlignment="Center" FontSize="Large" HorizontalOptions="End"/>
                    </Grid>
                </Grid>
            </Border>
            <Border Stroke="#232c39" StrokeShape="5" Margin="10" Padding="0" >
                <Grid RowDefinitions="Auto, *">
                    <!-- Header Section -->
                    <Grid BackgroundColor="#232c39">
                        <Label Text="Transações" 
                           Grid.ColumnSpan="3"
                           FontAttributes="Bold" 
                           FontSize="Header" 
                           TextColor="#d6e0eb"
                           Padding="10"
                           HorizontalOptions="Start"
                           />
                        <Label Text="Agosto/2026" 
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           FontAttributes="Bold" 
                           FontSize="Header" 
                           TextColor="#d6e0eb"
                           Padding="10"
                           HorizontalOptions="End"
                           />
                    </Grid>
                    <!-- Content Section -->
                    <!--collection view com as transações do mes. headers: Transações,Data,Categoria,Valor, #(sem header, icone de edit em cada line)-->
                    <CollectionView Grid.Row="1" ItemsSource="{Binding Transactions}" Margin="0,10,0,0">
                        <!--<CollectionView.Header>
                            <Grid ColumnDefinitions="2*, 1.2*, 1*, 40" Padding="10" BackgroundColor="#232c39">
                                <Label Text="Transação" FontAttributes="Bold" TextColor="#d6e0eb"/>
                                <Label Grid.Column="1" Text="Data" FontAttributes="Bold" TextColor="#d6e0eb" HorizontalTextAlignment="Center"/>
                                --><!--<Label Grid.Column="2" Text="Categoria" FontAttributes="Bold" TextColor="#d6e0eb" HorizontalTextAlignment="Center"/>--><!--
                                <Label Grid.Column="2" Text="Valor" FontAttributes="Bold" TextColor="#d6e0eb" HorizontalTextAlignment="End"/>
                            </Grid>
                        </CollectionView.Header>-->
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="2*, 1.2*, 1*, 40" Padding="5,0,5,0" VerticalOptions="Center" RowSpacing="0">
                                    <Label Text="{Binding Description}" 
                                           TextColor="#d6e0eb" 
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center"
                                           />
                                    <Label Grid.Column="1" 
                                           Text="{Binding Date, StringFormat='{0:dd/MM}'}" 
                                           TextColor="#d6e0eb" 
                                           HorizontalTextAlignment="Center"
                                           VerticalOptions="Center"
                                           />

                                    <!--<Label Grid.Column="2" 
                                           Text="{Binding Category}" 
                                           TextColor="#d6e0eb" 
                                           HorizontalTextAlignment="Center"
                                           VerticalOptions="Center"
                                           />-->

                                    <Label Grid.Column="2" 
                                           Text="{Binding Amount, StringFormat='{0:N2}'}" 
                                           TextColor="{Binding Amount, Converter={StaticResource AmountToColorConverter}}" 
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="End"
                                           VerticalOptions="Center"/>

                                    <Button Grid.Column="3" 
                                                 BackgroundColor="Transparent"                                                
                                                 VerticalOptions="Center">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="Icons"
                                                             Color="#3ca7f7"
                                                             Size="10"
                                                             Glyph="{x:Static Icons:IconFont.Pencil}"
                                                             />
                                        </Button.ImageSource>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Nenhuma transação encontrada." 
                                   HorizontalOptions="Center" 
                                   Margin="20" 
                                   TextColor="#758292"/>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
